# Core runtime
HUNT_NODE_ENV=development
HUNT_PORT=4000
HUNT_LOG_LEVEL=info

# Database
HUNT_MONGODB_URI=mongodb://localhost:27017
HUNT_MONGODB_DB_NAME=hunt_dev
# Optional: used only for running server Mongo integration tests
# HUNT_TEST_MONGODB_URI=mongodb://localhost:27017

# GitHub OAuth
HUNT_GITHUB_CLIENT_ID=your_github_client_id
HUNT_GITHUB_CLIENT_SECRET=your_github_client_secret
# Optional: token for clone traffic poller
# HUNT_GITHUB_TOKEN=github_pat_xxx

# Security
HUNT_JWT_SECRET=change_this_to_a_long_random_value
HUNT_SIGNING_SECRET=change_this_to_a_long_random_value

# Optional tuning
# HUNT_HTTP_MAX_BODY_BYTES=1048576
# HUNT_METRICS_POLL_INTERVAL_MS=60000
# HUNT_METRICS_POLL_BATCH_SIZE=20
# HUNT_METRICS_POLL_RETRY_ATTEMPTS=3
# HUNT_METRICS_POLL_RETRY_DELAY_MS=500
# HUNT_SIGNATURE_MAX_AGE_SECONDS=300
# HUNT_INGESTION_MAX_REQUESTS_PER_MINUTE=120
